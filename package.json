{
  "name": "codeviz-monorepo",
  "version": "1.0.0",
  "description": "CodeViz Animated Code & DSA Visualizer Monorepo",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run start:server\" \"npm run start:client\"",
    "build:client": "npm run build --prefix client",
    "build:server": "npm run build --prefix server",
    "start:client": "npm run dev --prefix client",
    "start:server": "npm run dev --prefix server"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  },
  "dependencies": {
    "acorn": "^8.14.0",
    "acorn-walk": "^8.3.4",
    "cors": "^2.8.5",
    "escodegen": "^2.1.0",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "mongoose": "^8.9.5",
    "nanoid": "^3.3.8",
    "socket.io": "^4.8.1",
    "uuid": "^11.0.5"
  }
}
